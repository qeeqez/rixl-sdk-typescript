{
  "name": "@rixl/api-sdk",
  "version": "2.0.0",
  "description": "RIXL public API SDK generated from the public OpenAPI spec.",
  "author": "Rixl Inc.",
  "repository": {
    "type": "git",
    "url": "https://github.com/qeeqez/rixl-sdk-typescript.git"
  },
  "keywords": [
    "rixl",
    "sdk",
    "api",
    "openapi",
    "typescript"
  ],
  "license": "SEE LICENSE IN LICENSE.md",
  "main": "./dist/index.js",
  "type": "module",
